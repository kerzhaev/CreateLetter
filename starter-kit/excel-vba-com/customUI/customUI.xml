<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<customUI xmlns="http://schemas.microsoft.com/office/2006/01/customui" onLoad="RibbonOnLoad">
  <ribbon>
    <tabs>
      <tab id="tabWorkbookApp" label="Работа с книгой">
        <group id="grpWorkbookMain" label="Команды">
          <button id="btnOpenMainForm"
                  label="Открыть форму"
                  size="large"
                  imageMso="FileOpen"
                  onAction="RibbonOpenMainForm"
                  screentip="Открыть форму"
                  supertip="Открывает основную пользовательскую форму." />
          <button id="btnOpenHistoryForm"
                  label="История"
                  size="large"
                  imageMso="FindDialog"
                  onAction="RibbonOpenHistoryForm"
                  screentip="История"
                  supertip="Открывает форму истории или поиска." />
          <button id="btnSelectTemplateFolder"
                  label="Папка шаблонов"
                  size="large"
                  imageMso="FileOpen"
                  onAction="RibbonSelectTemplateFolder"
                  screentip="Папка шаблонов"
                  supertip="Позволяет выбрать папку шаблонов." />
          <button id="btnSelectOutputFolder"
                  label="Папка выгрузки"
                  size="large"
                  imageMso="FileSaveAs"
                  onAction="RibbonSelectOutputFolder"
                  screentip="Папка выгрузки"
                  supertip="Позволяет выбрать папку сохранения файлов." />
          <button id="btnShowAbout"
                  label="О программе"
                  size="large"
                  imageMso="FileProperties"
                  onAction="RibbonShowAbout"
                  screentip="О программе"
                  supertip="Показывает краткую информацию о книге и настройках." />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
