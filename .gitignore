# Временные файлы Excel (мусор, который появляется при открытии книги)
~$*
*.tmp
*.xlsx

# Системные файлы
thumbs.db
desktop.ini
.DS_Store

# Папка с историей чатов Cursor (она может быть огромной, нам она в гите не нужна)
.cursor/

# Если ты не хочешь хранить архив в гите (так как файлы большие), можно раскомментировать строку ниже:
# _Archive/

# Restore points are local safety artifacts, not project history.
filesarchive/

# Local workbook/runtime artifacts
Backups/
_tmp_export/
CreateLetter.xlsm
LetterTemplate.docx
LetterTemplateFOU.docx
CreateLetter.xlsm.modules/*.frx

# Local AI tooling / skills are not part of the public source repository
.codex/
.agents/

# Python helper caches
scripts/__pycache__/
CreateLetter.xlsm.modules/*.log
